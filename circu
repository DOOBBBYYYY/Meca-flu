def circu(u, v, x, y):
    c = 0.0  # circulation finale à renvoyer (on l'initialise en float avec .0)
    ci = 0.0

    for i in range(len(x) - 1):
        if float(x[i]) == float(x[i+1]):
            ci = float(y[i+1] - y[i]) / 2.0 * float(v[i] + v[i+1])
            c = c + ci
            
        if float(y[i]) == float(y[i+1]):
            ci = float(x[i+1] - x[i]) / 2.0 * float(u[i] + u[i+1])
            c = c + ci 

    return c
