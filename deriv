def deriv(f_left, f_c, f_right, type_left, type_c, type_right, h):
    
    if type_c == 0:
        return 0.0

    if type_left != 0 and type_right != 0:
        v = (f_right - f_left) / (2 * h)
        
    elif type_left == 0 and type_right != 0:
        v = (f_right - f_c) / h
        
    elif type_left != 0 and type_right == 0:
        v = (f_c - f_left) / h
        
    else:
        v = 0.0 

    return v
